# XMPP Configuration
XMPP_JID=bot@example.com
XMPP_PASSWORD=your_xmpp_password
XMPP_DEFAULT_RECEIVER=user@example.com
XMPP_ALLOWED_JIDS=user@example.com,admin@example.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Router Configuration (optional — use a separate OpenAI-compatible API for routing)
# ROUTER_MODEL=deepseek-chat
# ROUTER_API_KEY=your_deepseek_api_key
# ROUTER_API_BASE_URL=https://api.deepseek.com

# Timezone (IANA name, used for current-time display in chat)
# USER_TIMEZONE=Europe/Berlin

# Send Later (Thunderbird extension) — schedule draft emails for business hours
# SEND_LATER_ENABLED=true
# SEND_LATER_START_HOUR=8
# SEND_LATER_END_HOUR=18

# Memory
MEMORY_FILE=data/memory.json

# Plugins (comma-separated module names, only listed plugins are loaded)
PLUGINS=business_assistant_imap,business_assistant_calendar,business_assistant_rtm

# Conversation history
MAX_CONVERSATION_HISTORY=100

# IMAP Configuration (required for business_assistant_imap plugin)
# IMAP_SERVER=imap.example.com
# IMAP_USERNAME=your_username
# IMAP_PASSWORD=your_password
# IMAP_PORT=993
# IMAP_USE_SSL=true
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
# EMAIL_FROM_ADDRESS=you@example.com

# Logging
# LOG_LEVEL=INFO
# LOG_DIR=logs
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=3

# FTP Upload Configuration (optional, enables attachment URL generation)
# FTP_HOST=ftp.example.com
# FTP_USERNAME=your_username
# FTP_PASSWORD=your_password
# FTP_PORT=21
# FTP_USE_TLS=true
# FTP_BASE_PATH=/uploads
# FTP_BASE_URL=https://example.com/uploads

# Google Calendar Configuration (required for business_assistant_calendar plugin)
# GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
# GOOGLE_CALENDAR_TOKEN_PATH=token.json
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CALENDAR_TIMEZONE=Europe/Berlin
# GOOGLE_CALENDAR_FREE_CHECK_IDS=cal1@group.calendar.google.com,cal2@group.calendar.google.com

# Startup greeting (sends a message to all allowed JIDs when the bot starts)
# STARTUP_GREETING_ENABLED=true
# STARTUP_GREETING_MESSAGE=Hi, how may I assist you today?

# Remember The Milk Configuration (required for business_assistant_rtm plugin)
# RTM_API_KEY=your_api_key_here
# RTM_SHARED_SECRET=your_shared_secret_here
# Token: run `uv run python tools/rtm_auth.py` to generate data/rtm_token
